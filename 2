<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Happy 19th Birthday 💙</title>
    <style>
        /* ════════════════════════════════════════
   TOKENS
════════════════════════════════════════ */
        :root {
            --navy: #07111f;
            --deep: #0b1d38;
            --mid: #1e5296;
            --blue: #2b6cb8;
            --glow: #5ba4f5;
            --pale: #b8d8fa;
            --frost: #e8f3ff;
            --white: #ffffff;

            --paper: #f4ede2;
            --paper-dark: #e6d9c8;
            --paper-tone: #d4c4ae;
            --ink: #261e14;
            --ink-mid: #4a3b2a;
            --ink-light: #7a6550;

            --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);
            --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        /* ════════════════════════════════════════
   RESET
════════════════════════════════════════ */
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: 'Georgia', 'Times New Roman', serif;
            background: var(--navy);
            color: var(--white);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        img {
            display: block;
            max-width: 100%;
        }

        button {
            cursor: pointer;
            border: none;
            outline: none;
            background: none;
        }

        /* ════════════════════════════════════════
   GLOBAL TRANSITIONS
════════════════════════════════════════ */
        .fade-section {
            opacity: 0;
            transform: translateY(28px);
            transition: opacity 1s var(--ease-smooth), transform 1s var(--ease-smooth);
        }

        .fade-section.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ════════════════════════════════════════
   FULL-SCREEN VEIL — entrance loader, auto-fades to reveal cake
════════════════════════════════════════ */
        #veil {
            position: fixed;
            inset: 0;
            z-index: 9000;
            background: var(--navy);
            pointer-events: none;
            /* never block candle — scroll-lock handles interaction */
            opacity: 1;
            transition: opacity 0.9s var(--ease-smooth);
        }

        #veil.faded {
            opacity: 0;
            pointer-events: none;
        }

        /* Scroll lock — applied to body until candle is blown */
        body.scroll-locked {
            overflow: hidden;
            touch-action: none;
            /* prevent momentum scroll on iOS */
        }

        /* ════════════════════════════════════════
   SCENE 1 — CAKE
════════════════════════════════════════ */
        #scene-cake {
            min-height: 100vh;
            min-height: 100svh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            background:
                radial-gradient(ellipse 70% 55% at 50% 38%, #163d74 0%, transparent 70%),
                radial-gradient(ellipse 100% 100% at 50% 100%, #07111f 0%, transparent 60%),
                var(--navy);
        }

        /* Starfield */
        #starfield {
            position: absolute;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .star {
            position: absolute;
            border-radius: 50%;
            background: white;
            animation: twinkle var(--dur, 3s) ease-in-out infinite var(--del, 0s);
        }

        @keyframes twinkle {

            0%,
            100% {
                opacity: var(--lo, 0.1);
            }

            50% {
                opacity: var(--hi, 0.7);
            }
        }

        /* Title */
        .cake-title-wrap {
            position: relative;
            height: 2.8rem;
            margin-bottom: 2.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 0 2rem;
            z-index: 15;
        }

        .cake-title {
            font-family: 'Georgia', serif;
            font-weight: 300;
            font-style: italic;
            font-size: clamp(1.25rem, 4.5vw, 1.9rem);
            letter-spacing: 0.12em;
            color: var(--pale);
            text-align: center;
            position: absolute;
            transition: opacity 0.8s ease, transform 0.8s ease;
            white-space: normal;
            max-width: 100%;
        }

        .cake-title.hide {
            opacity: 0;
            transform: translateY(-14px);
        }

        #title-b {
            opacity: 0;
            transform: translateY(14px);
            transition: opacity 0.9s ease 0.3s, transform 0.9s ease 0.3s;
            pointer-events: none;
        }

        #title-b.show {
            opacity: 1;
            transform: translateY(0);
        }

        /* Cake SVG */
        .cake-container {
            position: relative;
            width: min(280px, 78vw);
            filter: drop-shadow(0 0 20px rgba(43, 108, 184, 0.15));
            z-index: 5;
        }

        .cake-container svg {
            width: 100%;
            height: auto;
        }

        /* Flame animations */
        .flame-body {
            transform-origin: 50% 100%;
            transform-box: fill-box;
            animation: flameWave 1.1s ease-in-out infinite alternate;
        }

        .flame-core {
            transform-origin: 50% 100%;
            transform-box: fill-box;
            animation: flameWave 0.75s ease-in-out infinite alternate-reverse;
        }

        @keyframes flameWave {
            0% {
                transform: scaleX(1) scaleY(1) rotate(-2deg);
            }

            25% {
                transform: scaleX(0.9) scaleY(1.08) rotate(1.5deg);
            }

            75% {
                transform: scaleX(1.08) scaleY(0.95) rotate(-1deg);
            }

            100% {
                transform: scaleX(0.93) scaleY(1.04) rotate(2deg);
            }
        }

        .flame-glow {
            animation: glowBeat 1.5s ease-in-out infinite;
        }

        @keyframes glowBeat {

            0%,
            100% {
                opacity: 0.25;
                transform: scale(1);
            }

            50% {
                opacity: 0.5;
                transform: scale(1.15);
            }
        }

        /* Blown state */
        .flame-group.blown .flame-body,
        .flame-group.blown .flame-core,
        .flame-group.blown .flame-glow,
        .flame-group.blown .flame-tip {
            opacity: 0;
            animation: none;
            transition: opacity 0.5s ease;
        }

        /* Smoke puff after blow */
        .smoke {
            opacity: 0;
            transform-origin: center bottom;
            animation: none;
        }

        .flame-group.blown .smoke {
            animation: smokePuff 1.2s ease-out forwards;
        }

        @keyframes smokePuff {
            0% {
                opacity: 0;
                transform: translateY(0) scale(0.4);
            }

            25% {
                opacity: 0.35;
                transform: translateY(-6px) scale(0.8);
            }

            70% {
                opacity: 0.2;
                transform: translateY(-14px) scale(1.3);
            }

            100% {
                opacity: 0;
                transform: translateY(-22px) scale(1.6);
            }
        }

        /* Hint */
        .candle-hint {
            margin-top: 2.2rem;
            font-size: 0.72rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--blue);
            animation: hintPulse 2s ease-in-out infinite;
            transition: opacity 0.5s ease;
            position: relative;
            z-index: 15;
        }

        @keyframes hintPulse {

            0%,
            100% {
                opacity: 0.45;
            }

            50% {
                opacity: 1;
            }
        }

        .candle-hint.gone {
            opacity: 0;
        }

        /* Scroll arrow */
        .scroll-down {
            position: absolute;
            bottom: 2.2rem;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            color: var(--blue);
            font-size: 0.62rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            opacity: 0;
            pointer-events: none;
            transition: opacity 1.2s ease;
        }

        .scroll-down.show {
            opacity: 1;
        }

        .arrow-shaft {
            width: 1px;
            height: 28px;
            background: linear-gradient(to bottom, transparent, var(--glow));
            animation: shaftDrop 1.6s ease-in-out infinite;
        }

        .arrow-head {
            width: 8px;
            height: 8px;
            border-right: 1.5px solid var(--glow);
            border-bottom: 1.5px solid var(--glow);
            transform: rotate(45deg);
            margin-top: -6px;
            animation: shaftDrop 1.6s ease-in-out infinite 0.2s;
        }

        @keyframes shaftDrop {

            0%,
            100% {
                opacity: 0.4;
                transform: translateY(-3px) rotate(45deg);
            }

            50% {
                opacity: 1;
                transform: translateY(3px) rotate(45deg);
            }
        }

        .arrow-shaft {
            animation: shaftDropLine 1.6s ease-in-out infinite;
        }

        @keyframes shaftDropLine {

            50% {
                opacity: 1;
                transform: translateY(3px);
            }
        }

        /* Cinematic Blur Overlay */
        .cake-blur-layer {
            position: absolute;
            inset: 0;
            z-index: 10;
            background: rgba(7, 17, 31, 0.35);
            backdrop-filter: blur(0px);
            -webkit-backdrop-filter: blur(0px);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.6s var(--ease-smooth), backdrop-filter 0.6s var(--ease-smooth);
        }

        .cake-blur-layer.active {
            opacity: 1;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        /* ════════════════════════════════════════
   SCENE 2 — LETTER
════════════════════════════════════════ */
        /* ════════════════════════════════════════
   SCENE 2 — VINTAGE LETTER
════════════════════════════════════════ */
        #scene-letter {
            min-height: 100vh;
            min-height: 100svh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 5rem 1.25rem 5rem;
            background:
                radial-gradient(ellipse 70% 50% at 50% 85%, #0e2550 0%, transparent 60%),
                radial-gradient(ellipse 50% 35% at 20% 20%, #07111f 0%, transparent 55%),
                var(--navy);
            position: relative;
        }

        /* Subtle dust particles in bg */
        #scene-letter::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                radial-gradient(1px 1px at 12% 28%, rgba(220, 180, 130, .07), transparent),
                radial-gradient(1px 1px at 74% 63%, rgba(220, 180, 130, .05), transparent),
                radial-gradient(1px 1px at 38% 81%, rgba(220, 180, 130, .06), transparent),
                radial-gradient(1px 1px at 89% 14%, rgba(220, 180, 130, .04), transparent);
            pointer-events: none;
        }

        /* ── Envelope flap above card ── */
        .envelope-flap {
            width: min(620px, calc(100vw - 2.5rem));
            height: 38px;
            position: relative;
            z-index: 2;
            overflow: hidden;
            flex-shrink: 0;
        }

        .envelope-flap svg {
            width: 100%;
            height: 100%;
            display: block;
        }

        /* ── Main paper card ── */
        .paper-card {
            position: relative;
            max-width: 620px;
            width: 100%;
            background: #f0e6cf;
            border-radius: 0 0 2px 2px;
            padding: clamp(2.2rem, 6vw, 4rem) clamp(2rem, 6vw, 3.8rem) clamp(2rem, 5vw, 3rem);
            overflow: visible;
            box-shadow:
                0 2px 0 #c8b08a,
                0 6px 18px rgba(0, 0, 0, .22),
                0 24px 60px rgba(0, 0, 0, .35),
                0 60px 120px rgba(0, 0, 0, .3),
                inset 0 0 120px rgba(160, 110, 60, .07);
            /* Slight random tilt for worn-letter feel */
            transform: rotate(-0.4deg);
        }

        /* ── Aged paper layers ── */
        .paper-card::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background:
                /* aged yellowing corners */
                radial-gradient(ellipse 55% 40% at 0% 0%, rgba(180, 130, 60, .18) 0%, transparent 65%),
                radial-gradient(ellipse 45% 35% at 100% 0%, rgba(160, 110, 50, .14) 0%, transparent 60%),
                radial-gradient(ellipse 60% 40% at 100% 100%, rgba(190, 140, 70, .16) 0%, transparent 60%),
                radial-gradient(ellipse 50% 40% at 0% 100%, rgba(170, 120, 55, .13) 0%, transparent 55%),
                /* centre lightening */
                radial-gradient(ellipse 70% 65% at 50% 45%, rgba(255, 248, 230, .35) 0%, transparent 70%),
                /* horizontal ruled lines */
                repeating-linear-gradient(180deg, transparent, transparent 30px,
                    rgba(140, 100, 55, .07) 30px, rgba(140, 100, 55, .07) 31px);
            pointer-events: none;
            z-index: 0;
        }

        /* ── Worm-eaten / foxing spots ── */
        .paper-card::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background:
                /* water stain top-right */
                radial-gradient(ellipse 70px 55px at 88% 8%, rgba(150, 100, 50, .11) 30%, transparent 75%),
                /* foxing spot mid-left */
                radial-gradient(ellipse 22px 18px at 6% 55%, rgba(130, 85, 40, .09) 40%, transparent 80%),
                /* faint brown tide-mark bottom */
                radial-gradient(ellipse 200px 30px at 50% 98%, rgba(140, 95, 45, .08) 30%, transparent 70%),
                /* second coffee ring */
                radial-gradient(ellipse 48px 42px at 82% 72%, rgba(120, 80, 35, .08) 35%, transparent 72%);
            pointer-events: none;
            z-index: 0;
        }

        /* ── Torn left edge ── */
        .torn-edge {
            position: absolute;
            top: 0;
            left: -1px;
            bottom: 0;
            width: 18px;
            background:
                radial-gradient(ellipse 14px 8px at 0% 7%, #f0e6cf 55%, transparent 55%),
                radial-gradient(ellipse 12px 9px at 0% 15%, #f0e6cf 55%, transparent 55%),
                radial-gradient(ellipse 16px 7px at 0% 23%, #f0e6cf 55%, transparent 55%),
                radial-gradient(ellipse 10px 10px at 0% 31%, #f0e6cf 55%, transparent 55%),
                radial-gradient(ellipse 14px 8px at 0% 40%, #f0e6cf 55%, transparent 55%),
                radial-gradient(ellipse 12px 7px at 0% 49%, #f0e6cf 55%, transparent 55%),
                radial-gradient(ellipse 16px 9px at 0% 57%, #f0e6cf 55%, transparent 55%),
                radial-gradient(ellipse 11px 8px at 0% 65%, #f0e6cf 55%, transparent 55%),
                radial-gradient(ellipse 15px 7px at 0% 74%, #f0e6cf 55%, transparent 55%),
                radial-gradient(ellipse 13px 9px at 0% 82%, #f0e6cf 55%, transparent 55%),
                radial-gradient(ellipse 16px 8px at 0% 91%, #f0e6cf 55%, transparent 55%),
                radial-gradient(ellipse 12px 7px at 0% 100%, #f0e6cf 55%, transparent 55%);
            pointer-events: none;
            z-index: 3;
        }

        /* ── Fold crease lines — fixed pixel offsets, never cut through text ── */
        .fold-crease {
            position: absolute;
            left: 0;
            right: 0;
            height: 1px;
            pointer-events: none;
            z-index: 3;
        }

        .fold-crease.top {
            top: 148px;
            background: linear-gradient(to right, transparent 3%, rgba(120, 85, 40, .18) 15%, rgba(120, 85, 40, .25) 50%, rgba(120, 85, 40, .18) 85%, transparent 97%);
        }

        .fold-crease.bottom {
            top: 296px;
            background: linear-gradient(to right, transparent 3%, rgba(120, 85, 40, .15) 15%, rgba(120, 85, 40, .22) 50%, rgba(120, 85, 40, .15) 85%, transparent 97%);
        }

        /* tiny shadow beneath crease */
        .fold-crease::after {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            top: 1px;
            height: 2px;
            background: inherit;
            opacity: 0.35;
            filter: blur(1px);
        }

        /* ── Wax seal ── */
        .wax-seal {
            position: absolute;
            bottom: -22px;
            left: 50%;
            transform: translateX(-50%);
            width: 52px;
            height: 52px;
            z-index: 10;
            filter: drop-shadow(0 4px 10px rgba(0, 0, 0, .45));
        }

        .wax-seal svg {
            width: 100%;
            height: 100%;
        }

        /* ── Postage stamp corner ── */
        .stamp {
            position: absolute;
            top: 18px;
            right: 18px;
            width: 52px;
            height: 62px;
            z-index: 4;
            opacity: 0.75;
        }

        .stamp-inner {
            width: 100%;
            height: 100%;
            background: #e8d8b8;
            border: 2px solid #b09060;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 3px;
            position: relative;
            overflow: hidden;
        }

        /* Perforated edges via box-shadow dots */
        .stamp-inner::before {
            content: '';
            position: absolute;
            inset: -5px;
            background: repeating-linear-gradient(0deg, transparent, transparent 6px, #f0e6cf 6px, #f0e6cf 8px),
                repeating-linear-gradient(90deg, transparent, transparent 6px, #f0e6cf 6px, #f0e6cf 8px);
            pointer-events: none;
        }

        .stamp-value {
            font-family: 'Georgia', serif;
            font-size: 0.5rem;
            letter-spacing: 0.08em;
            color: #7a5530;
            font-weight: bold;
            text-transform: uppercase;
            position: relative;
            z-index: 1;
        }

        .stamp-icon {
            font-size: 1.3rem;
            line-height: 1;
            position: relative;
            z-index: 1;
        }

        .stamp-country {
            font-family: 'Georgia', serif;
            font-size: 0.38rem;
            letter-spacing: 0.12em;
            color: #7a5530;
            text-transform: uppercase;
            position: relative;
            z-index: 1;
        }

        /* ── Left margin rule ── */
        .margin-rule {
            position: absolute;
            left: 56px;
            top: 0;
            bottom: 0;
            width: 1px;
            background: linear-gradient(to bottom, transparent 2%, rgba(180, 100, 80, .22) 15%, rgba(180, 100, 80, .22) 85%, transparent 98%);
            z-index: 1;
        }

        /* ── Typography ── */
        .letter-date {
            font-family: 'Georgia', serif;
            font-style: italic;
            font-size: 0.8rem;
            color: #7a6248;
            margin-bottom: 1.6rem;
            letter-spacing: 0.06em;
            position: relative;
            z-index: 1;
            text-align: right;
            padding-right: 70px;
            /* clear stamp */
        }

        .letter-greeting {
            font-family: 'Palatino Linotype', 'Palatino', 'Book Antiqua', Georgia, serif;
            font-size: clamp(1.05rem, 3vw, 1.3rem);
            font-style: italic;
            color: #3a2a18;
            margin-bottom: 1.2em;
            position: relative;
            z-index: 1;
        }

        .letter-body {
            font-family: 'Palatino Linotype', 'Palatino', 'Book Antiqua', Georgia, serif;
            font-size: clamp(0.93rem, 2.3vw, 1.05rem);
            line-height: 2.05;
            color: #2e2010;
            position: relative;
            z-index: 1;
            /* Slight uneven baseline to mimic handwritten ink */
            text-rendering: optimizeLegibility;
        }

        .letter-body p {
            margin-bottom: 1.2em;
        }

        .letter-body p:last-child {
            margin-bottom: 0;
        }

        .letter-body em {
            font-style: italic;
            color: #2357a0;
            /* ink bleed on emphasis */
            text-shadow: 0 0 8px rgba(30, 82, 150, .15);
        }

        /* Ink blot on first paragraph first letter */
        .letter-body p:first-of-type::first-letter {
            font-size: 2.8em;
            float: left;
            line-height: 0.75;
            margin: 0.1em 0.08em 0 0;
            color: #163d74;
            font-family: 'Palatino Linotype', Georgia, serif;
            font-style: italic;
            text-shadow: 1px 1px 0 rgba(22, 61, 116, .2), 0 0 12px rgba(22, 61, 116, .1);
        }

        .letter-sign {
            font-family: 'Palatino Linotype', 'Palatino', 'Book Antiqua', Georgia, serif;
            font-style: italic;
            font-size: 1.2rem;
            color: #4a2e18;
            margin-top: 1.8rem;
            text-align: right;
            position: relative;
            z-index: 1;
            /* simulate slightly shakier pen at end */
            letter-spacing: 0.02em;
        }

        .letter-line {
            opacity: 0;
            transform: translateY(10px);
            transition: opacity 0.8s var(--ease-smooth), transform 0.8s var(--ease-smooth);
        }

        .letter-line.vis {
            opacity: 1;
            transform: translateY(0);
        }

        /* ── Letter CTA ── */
        .letter-cta-wrap {
            margin-top: 4rem;
            display: flex;
            justify-content: center;
            opacity: 0;
            transition: opacity 1s ease;
        }

        .letter-cta-wrap.vis {
            opacity: 1;
        }

        .glow-btn {
            font-family: 'Palatino Linotype', 'Palatino', Georgia, serif;
            font-style: italic;
            font-size: 1rem;
            color: #a0c8e8;
            letter-spacing: 0.06em;
            padding: 0.9rem 2.4rem;
            border: 1px solid rgba(60, 110, 180, .4);
            border-radius: 1px;
            background: rgba(8, 18, 38, .6);
            cursor: pointer;
            position: relative;
            animation: btnGlow 3s ease-in-out infinite;
            transition: background 0.3s, color 0.3s, border-color 0.3s;
            text-shadow: 0 0 12px rgba(200, 140, 80, .3);
        }

        .glow-btn:hover {
            background: rgba(22, 61, 116, .4);
            color: #c0d8f8;
            border-color: rgba(60, 120, 200, .7);
        }

        @keyframes btnGlow {

            0%,
            100% {
                box-shadow: 0 0 10px rgba(60, 120, 200, .2), 0 0 30px rgba(60, 100, 200, .07);
            }

            50% {
                box-shadow: 0 0 20px rgba(60, 120, 200, .4), 0 0 50px rgba(60, 100, 200, .15);
            }
        }

        /* ════════════════════════════════════════
   SCENE 3 — HORIZONTAL GALLERY
════════════════════════════════════════ */
        #scene-gallery {
            min-height: 100vh;
            min-height: 100svh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 5rem 0 4rem;
            background:
                radial-gradient(ellipse 90% 60% at 50% 30%, #112d60 0%, transparent 60%),
                var(--navy);
            overflow: hidden;
        }

        .gallery-header {
            text-align: center;
            margin-bottom: 3.5rem;
            padding: 0 2rem;
        }

        .gallery-header h2 {
            font-family: 'Georgia', serif;
            font-weight: normal;
            font-style: italic;
            font-size: clamp(1.8rem, 5.5vw, 3.2rem);
            color: var(--pale);
            letter-spacing: 0.06em;
            line-height: 1.2;
        }

        .gallery-header p {
            margin-top: 0.6rem;
            font-family: 'Georgia', serif;
            font-size: 0.78rem;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            color: var(--blue);
            font-style: normal;
        }

        /* Track */
        .gallery-track-wrap {
            position: relative;
            width: 100%;
            overflow: hidden;
            padding: 40px 0 50px;
            cursor: grab;
            user-select: none;
            /* pan-y: lets page scroll vertically; horizontal drag is handled by pointerdown */
            touch-action: pan-y;
            -webkit-overflow-scrolling: touch;
        }

        .gallery-track-wrap:active {
            cursor: grabbing;
        }

        .gallery-track {
            display: flex;
            align-items: center;
            gap: 24px;
            will-change: transform;
            /* no CSS transition — rAF loop owns the transform */
            transition: none;
        }

        /* Cards */
        .g-card {
            flex: 0 0 auto;
            width: clamp(220px, 52vw, 300px);
            border-radius: 6px;
            overflow: hidden;
            position: relative;
            transition:
                transform 0.5s var(--ease-smooth),
                box-shadow 0.5s var(--ease-smooth),
                opacity 0.5s var(--ease-smooth),
                filter 0.5s var(--ease-smooth);
            transform: scale(0.88);
            opacity: 0.8;
            box-shadow: 0 6px 24px rgba(0, 0, 0, .35);
            filter: brightness(0.8) blur(1px);
        }

        .g-card.active {
            transform: scale(1.12);
            opacity: 1;
            box-shadow:
                0 18px 52px rgba(0, 0, 0, .6),
                0 0 0 1px rgba(91, 164, 245, .22),
                0 0 50px rgba(91, 164, 245, .16);
            filter: brightness(1.06) blur(0px);
            z-index: 2;
        }

        /* Photo frame */
        .g-photo {
            width: 100%;
            aspect-ratio: 3/4;
            background: linear-gradient(145deg, #163d74, #0b1d38);
            position: relative;
            overflow: hidden;
        }

        .g-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
            pointer-events: none;
        }

        .g-card.active .g-photo img {
            transform: scale(1.03);
        }

        .g-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: linear-gradient(145deg, #163d74 0%, #0b1d38 100%);
            color: var(--pale);
        }

        .g-placeholder svg {
            opacity: 0.35;
        }

        .g-placeholder span {
            font-size: 0.6rem;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            opacity: 0.35;
        }

        /* Caption overlay */
        .g-caption {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 2rem 1.2rem 1.2rem;
            background: linear-gradient(to top, rgba(7, 17, 31, .92) 0%, transparent 100%);
            font-family: 'Georgia', serif;
            font-style: italic;
            font-size: 0.9rem;
            color: var(--pale);
            letter-spacing: 0.03em;
            line-height: 1.5;
            opacity: 0;
            transform: translateY(6px);
            transition: opacity 0.4s ease, transform 0.4s ease;
        }

        .g-card.active .g-caption {
            opacity: 1;
            transform: translateY(0);
        }

        /* Dot indicators */
        .gallery-dots {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 2rem;
        }

        .g-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--mid);
            transition: background 0.4s ease, transform 0.4s ease;
        }

        .g-dot.active {
            background: var(--glow);
            transform: scale(1.4);
        }

        /* Drag hint */
        .drag-hint {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.65rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--mid);
            animation: hintPulse 2.5s ease-in-out infinite;
            transition: opacity 0.5s ease;
        }

        .drag-hint.gone {
            opacity: 0;
        }

        /* ════════════════════════════════════════
   LIGHTBOX
════════════════════════════════════════ */
        #lightbox {
            position: fixed;
            inset: 0;
            z-index: 8000;
            background: rgba(7, 17, 31, 0.94);
            backdrop-filter: blur(8px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.45s var(--ease-smooth);
        }

        #lightbox.open {
            opacity: 1;
            pointer-events: all;
        }

        .lb-inner {
            position: relative;
            max-width: min(520px, 90vw);
            width: 100%;
            transform: scale(0.92);
            transition: transform 0.45s var(--ease-spring);
        }

        #lightbox.open .lb-inner {
            transform: scale(1);
        }

        .lb-img-wrap {
            width: 100%;
            aspect-ratio: 3/4;
            border-radius: 5px;
            overflow: hidden;
            background: linear-gradient(145deg, #163d74, #0b1d38);
            box-shadow: 0 30px 80px rgba(0, 0, 0, .7);
        }

        .lb-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .lb-ph {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 12px;
            color: var(--pale);
        }

        .lb-ph svg {
            opacity: 0.3;
            width: 64px;
            height: 64px;
        }

        .lb-ph p {
            font-size: 0.7rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            opacity: 0.3;
        }

        .lb-caption {
            margin-top: 1.2rem;
            font-family: 'Georgia', serif;
            font-style: italic;
            font-size: 1rem;
            color: var(--pale);
            text-align: center;
            letter-spacing: 0.04em;
            line-height: 1.6;
        }

        .lb-close {
            position: absolute;
            top: -2.6rem;
            right: 0;
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--pale);
            font-size: 1.4rem;
            opacity: 0.6;
            transition: opacity 0.2s, transform 0.2s;
            cursor: pointer;
        }

        .lb-close:hover {
            opacity: 1;
            transform: rotate(90deg);
        }

        /* ════════════════════════════════════════
   SCENE 4 — ENDING
════════════════════════════════════════ */
        #scene-end {
            min-height: 100vh;
            min-height: 100svh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 4rem 2rem;
            position: relative;
            overflow: hidden;
            background:
                radial-gradient(ellipse 70% 60% at 50% 55%, #0f2a5a 0%, transparent 65%),
                radial-gradient(ellipse 100% 100% at 50% 100%, #07111f 0%, transparent 55%),
                var(--navy);
        }

        /* Particles */
        .particle {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
            animation: floatUp var(--dur, 8s) ease-in-out infinite var(--del, 0s);
            opacity: 0;
        }

        @keyframes floatUp {
            0% {
                transform: translate(0, 0) scale(1);
                opacity: 0;
            }

            15% {
                opacity: var(--hi, 0.45);
            }

            85% {
                opacity: var(--hi, 0.35);
            }

            100% {
                transform: translate(var(--dx, 0px), var(--dy, -180px)) scale(0.4);
                opacity: 0;
            }
        }

        /* Glow rings */
        .end-ring {
            position: absolute;
            border-radius: 50%;
            border: 1px solid rgba(91, 164, 245, .1);
            animation: ringPulse 5s ease-in-out infinite var(--del, 0s);
            pointer-events: none;
        }

        @keyframes ringPulse {
            0% {
                transform: scale(0.85);
                opacity: 0;
            }

            20% {
                opacity: 1;
            }

            100% {
                transform: scale(1.6);
                opacity: 0;
            }
        }

        .end-quote {
            font-family: 'Georgia', serif;
            font-weight: normal;
            font-style: italic;
            font-size: clamp(1.5rem, 5vw, 3rem);
            color: var(--pale);
            letter-spacing: 0.04em;
            line-height: 1.45;
            max-width: 700px;
            position: relative;
            z-index: 1;
            opacity: 0;
            transform: translateY(24px);
            transition: opacity 1.4s var(--ease-smooth), transform 1.4s var(--ease-smooth);
        }

        .end-quote.vis {
            opacity: 1;
            transform: translateY(0);
        }

        .end-quote::before {
            content: '\201C';
            position: absolute;
            top: -0.4em;
            left: -0.3em;
            font-size: 4em;
            color: rgba(91, 164, 245, .08);
            font-family: 'Georgia', serif;
            line-height: 1;
            pointer-events: none;
        }

        .end-sub {
            margin-top: 2.5rem;
            font-size: clamp(0.85rem, 2.5vw, 1rem);
            letter-spacing: 0.32em;
            text-transform: uppercase;
            color: var(--glow);
            font-family: 'Georgia', serif;
            font-style: normal;
            position: relative;
            z-index: 1;
            opacity: 0;
            transition: opacity 1.4s ease 0.7s;
        }

        .end-sub.vis {
            opacity: 1;
        }

        .end-thank {
            margin-top: 1.4rem;
            font-family: 'Georgia', serif;
            font-style: italic;
            font-size: clamp(0.9rem, 2.5vw, 1.1rem);
            letter-spacing: 0.12em;
            color: var(--pale);
            position: relative;
            z-index: 1;
            opacity: 0;
            transform: translateY(10px);
            transition: opacity 1.2s ease, transform 1.2s ease;
        }

        .end-thank.vis {
            opacity: 0.75;
            transform: translateY(0);
        }

        .end-line {
            width: 60px;
            height: 1px;
            background: linear-gradient(to right, transparent, var(--glow), transparent);
            margin: 2.2rem auto 0;
            position: relative;
            z-index: 1;
            opacity: 0;
            transition: opacity 1s ease 1.2s;
        }

        .end-line.vis {
            opacity: 0.5;
        }

        /* ════════════════════════════════════════
   WISH MESSAGE (after candle blow)
════════════════════════════════════════ */
        #wish-msg {
            position: absolute;
            top: 58%;
            left: 50%;
            transform: translateX(-50%) translateY(0px);
            font-family: 'Georgia', serif;
            font-style: italic;
            font-size: clamp(0.95rem, 3vw, 1.2rem);
            color: var(--pale);
            letter-spacing: 0.08em;
            text-align: center;
            white-space: nowrap;
            pointer-events: none;
            z-index: 20;
            opacity: 0;
            text-shadow: 0 0 20px rgba(91, 164, 245, .4);
        }

        #wish-msg.wish-in {
            animation: wishFloat 2.8s ease-in-out forwards;
        }

        @keyframes wishFloat {
            0% {
                opacity: 0;
                transform: translateX(-50%) translateY(8px);
            }

            18% {
                opacity: 1;
                transform: translateX(-50%) translateY(-4px);
            }

            72% {
                opacity: 1;
                transform: translateX(-50%) translateY(-10px);
            }

            100% {
                opacity: 0;
                transform: translateX(-50%) translateY(-22px);
            }
        }

        /* ════════════════════════════════════════
   SECRET SMILE BUTTON + MODAL
════════════════════════════════════════ */
        .smile-btn-wrap {
            display: flex;
            justify-content: center;
            margin-top: 1.8rem;
            opacity: 0;
            transition: opacity 1s ease;
        }

        .smile-btn-wrap.vis {
            opacity: 1;
        }

        .smile-btn {
            font-family: 'Palatino Linotype', 'Palatino', Georgia, serif;
            font-style: italic;
            font-size: 0.88rem;
            color: var(--pale);
            letter-spacing: 0.06em;
            padding: 0.65rem 1.6rem;
            border: 1px solid rgba(91, 164, 245, .28);
            border-radius: 20px;
            background: rgba(11, 29, 56, .5);
            cursor: pointer;
            transition: background 0.3s, border-color 0.3s, transform 0.2s;
            animation: smileGlow 3.5s ease-in-out infinite;
        }

        .smile-btn:hover {
            background: rgba(30, 82, 150, .3);
            border-color: rgba(91, 164, 245, .55);
            transform: scale(1.03);
        }

        @keyframes smileGlow {

            0%,
            100% {
                box-shadow: 0 0 6px rgba(91, 164, 245, .1);
            }

            50% {
                box-shadow: 0 0 14px rgba(91, 164, 245, .3), 0 0 28px rgba(91, 164, 245, .1);
            }
        }

        /* Modal overlay */
        #smile-modal {
            position: fixed;
            inset: 0;
            z-index: 8500;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            background: rgba(7, 17, 31, .7);
            backdrop-filter: blur(6px);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease;
        }

        #smile-modal.open {
            opacity: 1;
            pointer-events: all;
        }

        .smile-card {
            position: relative;
            max-width: 420px;
            width: 100%;
            background: linear-gradient(145deg, #0e2248, #07111f);
            border: 1px solid rgba(91, 164, 245, .2);
            border-radius: 12px;
            padding: 2.5rem 2rem 2rem;
            text-align: center;
            box-shadow: 0 24px 70px rgba(0, 0, 0, .55), 0 0 40px rgba(91, 164, 245, .08);
            transform: scale(0.92) translateY(12px);
            transition: transform 0.4s var(--ease-spring);
        }

        #smile-modal.open .smile-card {
            transform: scale(1) translateY(0);
        }

        .smile-card-emoji {
            font-size: 2rem;
            margin-bottom: 1rem;
            display: block;
            animation: bobble 2.4s ease-in-out infinite;
        }

        @keyframes bobble {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-5px);
            }
        }

        .smile-card-text {
            font-family: 'Georgia', serif;
            font-style: italic;
            font-size: clamp(1rem, 3vw, 1.18rem);
            color: var(--pale);
            line-height: 1.7;
            letter-spacing: 0.03em;
        }

        .smile-card-close {
            position: absolute;
            top: 0.9rem;
            right: 1rem;
            background: none;
            border: none;
            color: var(--pale);
            opacity: 0.45;
            font-size: 1.1rem;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.2s;
            line-height: 1;
        }

        .smile-card-close:hover {
            opacity: 1;
            transform: rotate(90deg);
        }

        /* ════════════════════════════════════════
   CONFETTI
════════════════════════════════════════ */
        .confetti-piece {
            position: fixed;
            top: -12px;
            width: 7px;
            height: 10px;
            border-radius: 2px;
            pointer-events: none;
            z-index: 7000;
            opacity: 0;
            animation: confettiFall var(--cf-dur, 1.4s) ease-in var(--cf-del, 0s) forwards;
        }

        @keyframes confettiFall {
            0% {
                opacity: 1;
                transform: translateY(0) rotate(0deg) translateX(0);
            }

            25% {
                opacity: 1;
                transform: translateY(25vh) rotate(120deg) translateX(var(--cf-dx, 0px));
            }

            70% {
                opacity: 0.7;
                transform: translateY(65vh) rotate(280deg) translateX(calc(var(--cf-dx, 0px) * 1.4));
            }

            100% {
                opacity: 0;
                transform: translateY(105vh) rotate(420deg) translateX(calc(var(--cf-dx, 0px) * 1.8));
            }
        }

        /* ════════════════════════════════════════
   ENDING — "more loved" extra line
════════════════════════════════════════ */
        .end-loved {
            margin-top: 1.1rem;
            font-family: 'Georgia', serif;
            font-style: italic;
            font-size: clamp(0.88rem, 2.4vw, 1.05rem);
            letter-spacing: 0.1em;
            color: var(--glow);
            position: relative;
            z-index: 1;
            opacity: 0;
            transform: translateY(12px);
            transition: opacity 1.3s ease, transform 1.3s ease;
        }

        .end-loved.vis {
            opacity: 0.85;
            transform: translateY(0);
        }
    </style>
</head>

