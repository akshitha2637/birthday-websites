    <script>
        /* ══════════════════════════════════════════
           CONFIG — Edit everything here
        ══════════════════════════════════════════ */
        const CONFIG = {
            name: "",          // e.g. "Sara" — shown in cake title. Defaults to "She" if blank.
            age: 19,           // Age shown in cake title and birthday line

            letter: [
                "There are things I have kept folded somewhere deep — words I never quite found the courage to say out loud. Today, on the day you turn nineteen, I am letting them breathe for the first time.",
                "I have watched you move through this world with a quiet grace that most people mistake for simplicity. They are wrong. That softness is your <em>greatest strength</em> — it is the reason everything you touch becomes a little more alive.",
                "Nineteen years. The world has had nineteen years to know you, and still it does not deserve you. But I am grateful — endlessly, quietly, overwhelmingly grateful — that you exist in it.",
                "You laugh like you have never been hurt. You love like you have always been safe. And on the days when neither of those things feels true, know this: I see you. <em>All of you.</em>",
                "May nineteen be everything you dreamed of — and then, quietly, a little more.",
            ],

            endingMessage: "You are the most beautiful chapter of my life.",

            photos: [
                { src: null, caption: "That golden afternoon that felt like a dream" },
                { src: null, caption: "When you laughed and everything stopped" },
                { src: null, caption: "The quiet moment I knew" },
                { src: null, caption: "Sunlight and your smile — perfect" },
                { src: null, caption: "Every little thing you do is magic" },
                { src: null, caption: "Here's to a thousand more like this" },
            ],
        };

        /* ══════════════════════════════════════════
           UTILITIES
        ══════════════════════════════════════════ */
        const $ = id => document.getElementById(id);
        const qs = (sel, ctx = document) => ctx.querySelector(sel);
        const qsa = (sel, ctx = document) => [...ctx.querySelectorAll(sel)];

        function onVisible(elements, cb, options = {}) {
            const io = new IntersectionObserver(entries => {
                entries.forEach(e => { if (e.isIntersecting) cb(e.target, io); });
            }, { threshold: 0.12, ...options });
            elements.forEach(el => io.observe(el));
        }

        /* ══════════════════════════════════════════
           APPLY CONFIG — name, age, letter
        ══════════════════════════════════════════ */
        (function applyConfig() {
            const nameStr = CONFIG.name ? CONFIG.name : 'She';

            // ── Cake titles ──
            $('title-a').textContent = `${nameStr} turns ${CONFIG.age} today…`;
            $('title-b').textContent = `${nameStr} turns ${CONFIG.age} ✨`;

            // ── Letter: clear HTML, build from CONFIG.letter ──
            const body = document.querySelector('.letter-body');
            if (body) {
                body.innerHTML = CONFIG.letter
                    .map(p => `<p class="letter-line">${p}</p>`)
                    .join('');
            }

            // ── Ending message (stage 1 quote) ──
            const quoteEl = $('end-quote');
            if (quoteEl) quoteEl.textContent = CONFIG.endingMessage;

            // ── Ending sub-line (birthday line with age) ──
            const subEl = $('end-sub');
            if (subEl) subEl.innerHTML = `Happy ${CONFIG.age}th Birthday &nbsp;💙`;
        })();

        /* ══════════════════════════════════════════
           STARFIELD
        ══════════════════════════════════════════ */
        (function buildStars() {
            const sf = $('starfield');
            for (let i = 0; i < 60; i++) {
                const s = document.createElement('div');
                s.className = 'star';
                const size = Math.random() < 0.3 ? 3 : 2;
                s.style.left = `${Math.random() * 100}%`;
                s.style.top = `${Math.random() * 100}%`;
                s.style.width = `${size}px`;
                s.style.height = `${size}px`;
                s.style.setProperty('--dur', `${2.5 + Math.random() * 4.5}s`);
                s.style.setProperty('--del', `-${Math.random() * 6}s`);
                s.style.setProperty('--lo', `${0.05 + Math.random() * 0.15}`);
                s.style.setProperty('--hi', `${0.5 + Math.random() * 0.5}`);
                sf.appendChild(s);
            }
        })();

        /* ══════════════════════════════════════════
           GALLERY DATA — pulled from CONFIG
        ══════════════════════════════════════════ */
        const photos = CONFIG.photos;

        /* ══════════════════════════════════════════
           BUILD GALLERY
        ══════════════════════════════════════════ */
        const track = $('gallery-track');
        const dotsWrap = $('gallery-dots');

        const photoIconSVG = `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" width="52" height="52">
  <rect x="6" y="10" width="36" height="28" rx="4" stroke="currentColor" stroke-width="1.5"/>
  <circle cx="17" cy="20" r="4" stroke="currentColor" stroke-width="1.5"/>
  <path d="M6 32 L16 22 L24 30 L32 22 L42 32" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
</svg>`;

        photos.forEach((p, i) => {
            const card = document.createElement('div');
            card.className = 'g-card';
            card.dataset.index = i;

            const frame = document.createElement('div');
            frame.className = 'g-photo';

            if (p.src) {
                const img = document.createElement('img');
                img.src = p.src; img.alt = p.caption;
                frame.appendChild(img);
            } else {
                const ph = document.createElement('div');
                ph.className = 'g-placeholder';
                ph.innerHTML = `${photoIconSVG}<span>Add photo ${i + 1}</span>`;
                frame.appendChild(ph);
            }

            const cap = document.createElement('div');
            cap.className = 'g-caption';
            cap.textContent = p.caption;

            card.appendChild(frame);
            card.appendChild(cap);
            track.appendChild(card);

            const dot = document.createElement('div');
            dot.className = 'g-dot';
            dot.dataset.index = i;
            dotsWrap.appendChild(dot);
        });

        /* ══════════════════════════════════════════
           GALLERY — CONTINUOUS SMOOTH SCROLL + DRAG / TOUCH / CENTER-ZOOM
        ══════════════════════════════════════════ */
        (function galleryEngine() {
            const wrap = $('gallery-wrap');
            const cards = qsa('.g-card');
            const dots = qsa('.g-dot');
            const dragHint = $('drag-hint');
            const SPEED = 0.26;    // px per animation frame (~15px/sec at 60fps — slower & dreamier)
            const RESUME_DELAY = 3000;    // ms after user touch before auto resumes

            let gap = 24;
            let cardW = cards[0] ? cards[0].offsetWidth : 260;
            let step = cardW + gap;
            let totalW = step * cards.length;

            let rawOffset = 0;       // continuous pixel position (grows indefinitely)
            let isDragging = false;
            let startX = 0;
            let dragBase = 0;
            let paused = false;
            let resumeTimer = null;
            let rafId = null;
            let lastTime = null;
            let inView = false;
            let hintDismissed = false;

            /* ── Rebuild measurements on resize ── */
            function remeasure() {
                cardW = cards[0] ? cards[0].offsetWidth : 260;
                step = cardW + gap;
                totalW = step * cards.length;
            }
            // window.addEventListener('resize', remeasure); // Removed: Consolidated below to avoid double execution

            /* ── Apply transform directly (no CSS transition — rAF handles smoothness) ── */
            function applyRaw(offset) {
                track.style.transition = 'none';
                // Wrap offset so it loops seamlessly
                const wrapped = ((offset % totalW) + totalW) % totalW;
                track.style.transform = `translateX(${-(wrapped)}px)`;
                rawOffset = offset;
                updateActive(wrapped);
            }

            /* ── Smooth snap after drag (lerp to nearest card) ── */
            let snapTarget = null;
            let snapCurrent = null;
            function snapTo(offset) {
                snapCurrent = ((rawOffset % totalW) + totalW) % totalW;
                // Find nearest card centre
                const wrapW = wrap.offsetWidth;
                const visual = snapCurrent; // track's left edge displacement
                // which card index is closest to center?
                const centerX = visual + wrapW / 2;
                let best = 0, minD = Infinity;
                cards.forEach((c, i) => {
                    const cx = i * step + cardW / 2;
                    const d = Math.abs(cx - centerX);
                    if (d < minD) { minD = d; best = i; }
                });
                // target offset = position where card `best` is centred
                const targetWrapped = best * step - (wrapW / 2 - cardW / 2);
                // keep rawOffset in same "loop lap"
                const lap = Math.floor(rawOffset / totalW);
                snapTarget = lap * totalW + targetWrapped;
                lerpSnap();
            }

            function lerpSnap() {
                if (snapTarget === null) return;
                const wrapped = ((rawOffset % totalW) + totalW) % totalW;
                const lap = Math.floor(rawOffset / totalW);
                let current = lap * totalW + wrapped;
                const diff = snapTarget - current;
                if (Math.abs(diff) < 0.5) {
                    rawOffset = snapTarget;
                    applyRaw(rawOffset);
                    snapTarget = null;
                    if (!paused) startRaf();
                    return;
                }
                rawOffset = current + diff * 0.12;
                applyRaw(rawOffset);
                rafId = requestAnimationFrame(lerpSnap);
            }

            /* ── Active card detection ── */
            function updateActive(wrappedOffset) {
                const wrapW = wrap.offsetWidth;
                const centerX = wrappedOffset + wrapW / 2;
                let best = 0, minD = Infinity;
                cards.forEach((c, i) => {
                    const cx = i * step + cardW / 2;
                    const d = Math.abs(cx - centerX);
                    if (d < minD) { minD = d; best = i; }
                });
                cards.forEach((c, i) => c.classList.toggle('active', i === best));
                dots.forEach((d, i) => d.classList.toggle('active', i === best));
            }

            /* ── rAF loop ── */
            function tick(ts) {
                if (!inView || paused || isDragging || snapTarget !== null) {
                    lastTime = null;
                    return;
                }
                if (lastTime === null) lastTime = ts;
                const dt = Math.min(ts - lastTime, 64); // cap at ~2 frames to avoid jumps
                lastTime = ts;
                rawOffset += SPEED * (dt / 16.67);
                applyRaw(rawOffset);
                rafId = requestAnimationFrame(tick);
            }

            function startRaf() {
                if (rafId) cancelAnimationFrame(rafId);
                lastTime = null;
                rafId = requestAnimationFrame(tick);
            }

            function stopRaf() {
                if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
                lastTime = null;
            }

            /* ── Pause/resume helpers ── */
            function pauseAuto() {
                paused = true;
                stopRaf();
                clearTimeout(resumeTimer);
            }
            function scheduleResume() {
                clearTimeout(resumeTimer);
                resumeTimer = setTimeout(() => {
                    paused = false;
                    if (inView) startRaf();
                }, RESUME_DELAY);
            }

            /* ── Visibility observer ── */
            const visObs = new IntersectionObserver(entries => {
                entries.forEach(e => {
                    inView = e.isIntersecting;
                    if (inView && !paused && !isDragging) startRaf();
                    else if (!inView) stopRaf();
                });
            }, { threshold: 0.2 });
            visObs.observe($('scene-gallery'));

            /* ── Init ── */
            remeasure();
            applyRaw(0);

            // Re-center on resize
            window.addEventListener('resize', () => {
                remeasure();
                applyRaw(rawOffset);
            });

            /* ── Unified pointer events (mouse + touch + stylus) ── */
            wrap.addEventListener('pointerdown', e => {
                isDragging = true;
                startX = e.clientX;
                dragBase = rawOffset;
                wrap.setPointerCapture(e.pointerId);
                stopRaf();
                if (!hintDismissed) { dragHint.classList.add('gone'); hintDismissed = true; }
            });
            wrap.addEventListener('pointermove', e => {
                if (!isDragging) return;
                const dx = e.clientX - startX;
                applyRaw(dragBase - dx);
            });
            wrap.addEventListener('pointerup', e => {
                if (!isDragging) return;
                isDragging = false;
                paused = true;
                snapTo(rawOffset);
                scheduleResume();
            });
            wrap.addEventListener('pointercancel', e => {
                if (!isDragging) return;
                isDragging = false;
                paused = true;
                snapTo(rawOffset);
                scheduleResume();
            });

            /* Dot clicks */
            dots.forEach((d, i) => d.addEventListener('click', () => {
                const wrapW = wrap.offsetWidth;
                const target = i * step - (wrapW / 2 - cardW / 2);
                rawOffset = Math.floor(rawOffset / totalW) * totalW + target;
                snapTarget = rawOffset;
                pauseAuto();
                lerpSnap();
                scheduleResume();
            }));

            /* Card click → lightbox */
            cards.forEach((c, i) => {
                c.addEventListener('click', e => {
                    if (Math.abs(e.clientX - startX) > 6) return; // was a drag, not a click
                    const wrapped = ((rawOffset % totalW) + totalW) % totalW;
                    const wrapW = wrap.offsetWidth;
                    const centerX = wrapped + wrapW / 2;
                    let best = 0, minD = Infinity;
                    cards.forEach((cc, ii) => {
                        const cx = ii * step + cardW / 2;
                        const d = Math.abs(cx - centerX);
                        if (d < minD) { minD = d; best = ii; }
                    });
                    if (i !== best) {
                        // snap to clicked card first
                        const target = i * step - (wrapW / 2 - cardW / 2);
                        rawOffset = ((rawOffset / totalW) | 0) * totalW + target;
                        snapTarget = rawOffset;
                        pauseAuto();
                        lerpSnap();
                        scheduleResume();
                        return;
                    }
                    openLightbox(i);
                });
            });
        })();

        /* ══════════════════════════════════════════
           LIGHTBOX
        ══════════════════════════════════════════ */
        const lightbox = $('lightbox');

        function openLightbox(index) {
            const p = photos[index];
            const lbWrap = $('lb-img-wrap');
            lbWrap.innerHTML = '';

            if (p.src) {
                const img = document.createElement('img');
                img.src = p.src; img.alt = p.caption || '';
                lbWrap.appendChild(img);
            } else {
                const ph = document.createElement('div');
                ph.className = 'lb-ph';
                ph.innerHTML = `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="6" y="10" width="36" height="28" rx="4" stroke="currentColor" stroke-width="1.2"/>
      <circle cx="17" cy="20" r="4" stroke="currentColor" stroke-width="1.2"/>
      <path d="M6 32 L16 22 L24 30 L32 22 L42 32" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
    </svg><p>Add photo ${index + 1}</p>`;
                lbWrap.appendChild(ph);
            }

            $('lb-caption').textContent = p.caption || '';
            lightbox.classList.add('open');
            // Store previous overflow so we can restore it correctly
            lightbox._prevOverflow = document.body.style.overflow;
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            lightbox.classList.remove('open');
            // Restore previous state — don't clear scroll-locked class
            document.body.style.overflow = lightbox._prevOverflow || '';
        }

        $('lb-close').addEventListener('click', closeLightbox);
        lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

        /* ══════════════════════════════════════════
           PAGE INIT — veil auto-fades to reveal cake; scroll stays locked until candle
        ══════════════════════════════════════════ */
        // Veil auto-fades after entrance delay, revealing the cake (pointer-events: none so candle is always clickable)
        (function initVeil() {
            const veil = $('veil');
            // brief pause so the navy background renders cleanly, then reveal
            setTimeout(() => {
                veil.classList.add('faded');
            }, 350);
        })();

        /* ══════════════════════════════════════════
           CANDLE BLOW-OUT
        ══════════════════════════════════════════ */
        (function candleInit() {
            const flame = $('flame-group');
            const hint = $('candle-hint');
            const titleA = $('title-a');
            const titleB = $('title-b');
            const scrollD = $('scroll-down');
            let blown = false;

            flame.addEventListener('click', () => {
                if (blown) return;
                blown = true;

                flame.classList.add('blown');
                hint.classList.add('gone');
                $('cake-blur').classList.add('active'); // Activate blur on success blow logic

                // Unlock scroll — remove class and reset any inline overflow
                // unlockScroll is already defined in candleInit scope below
                setTimeout(unlockScroll, 850);

                // Safety fallback — ensure scroll never stays locked
                setTimeout(unlockScroll, 2500);

                // Show wish floating message after blow
                setTimeout(() => {
                    const wish = $('wish-msg');
                    wish.classList.add('wish-in');
                    setTimeout(() => wish.classList.remove('wish-in'), 3000);
                }, 600);

                setTimeout(() => {
                    titleA.classList.add('hide');
                    setTimeout(() => titleB.classList.add('show'), 350);
                }, 500);

                setTimeout(() => scrollD.classList.add('show'), 1600);
            });

            // Safety: if page is scrolled away from cake somehow, always unlock
            window.addEventListener('scroll', () => {
                if (!blown && window.scrollY > 50) unlockScroll();
            }, { once: true, passive: true });

            function unlockScroll() {
                document.body.classList.remove('scroll-locked');
                document.body.style.overflow = '';
                document.body.style.touchAction = '';
            }
        })();

        /* ══════════════════════════════════════════
           LETTER — STAGGERED REVEAL
        ══════════════════════════════════════════ */
        (function letterReveal() {
            // .letter-line elements are injected by applyConfig() which ran before this IIFE
            // Re-query here to pick up the dynamically-added paragraphs
            const lines = qsa('.letter-line');

            const io = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (!entry.isIntersecting) return;
                    const idx = lines.indexOf(entry.target);
                    setTimeout(() => entry.target.classList.add('vis'), idx * 130);
                    io.unobserve(entry.target);
                });
            }, { threshold: 0.08, rootMargin: '0px 0px -20px 0px' });

            lines.forEach(line => io.observe(line));

            const cta = $('letter-cta-wrap');
            if (cta) {
                const ctaObs = new IntersectionObserver(entries => {
                    entries.forEach(e => {
                        if (!e.isIntersecting) return;
                        setTimeout(() => e.target.classList.add('vis'), 300);
                        ctaObs.unobserve(e.target);
                    });
                }, { threshold: 0.4 });
                ctaObs.observe(cta);
            }

            // Smile button reveal
            const smileWrap = $('smile-btn-wrap');
            if (smileWrap) {
                const smileObs = new IntersectionObserver(entries => {
                    entries.forEach(e => {
                        if (!e.isIntersecting) return;
                        setTimeout(() => e.target.classList.add('vis'), 700);
                        smileObs.unobserve(e.target);
                    });
                }, { threshold: 0.35 });
                smileObs.observe(smileWrap);
            }

            const galleryBtn = $('to-gallery-btn');
            if (galleryBtn) {
                galleryBtn.addEventListener('click', () => {
                    $('scene-gallery').scrollIntoView({ behavior: 'smooth' });
                });
            }
        })();

        /* ══════════════════════════════════════════
           SECRET SMILE MODAL
        ══════════════════════════════════════════ */
        (function smileModal() {
            const modal = $('smile-modal');
            const btn = $('smile-btn');
            const close = $('smile-close');

            function openModal() {
                modal._prevOverflow = document.body.style.overflow;
                modal.classList.add('open');
                document.body.style.overflow = 'hidden';
            }
            function closeModal() {
                modal.classList.remove('open');
                document.body.style.overflow = modal._prevOverflow || '';
            }

            if (btn) btn.addEventListener('click', openModal);
            if (close) close.addEventListener('click', closeModal);
            modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
            document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
        })();

        /* ══════════════════════════════════════════
           SECTION FADE-IN — IntersectionObserver for .fade-section .visible
        ══════════════════════════════════════════ */
        (function initFadeSections() {
            const fadeEls = qsa('.fade-section');
            if (!fadeEls.length) return;

            const io = new IntersectionObserver(entries => {
                entries.forEach(e => {
                    if (!e.isIntersecting) return;
                    e.target.classList.add('visible');
                    io.unobserve(e.target);
                });
            }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

            fadeEls.forEach(el => {
                // If already in viewport on load (e.g. very tall screens), add immediately
                const rect = el.getBoundingClientRect();
                if (rect.top < window.innerHeight && rect.bottom > 0) {
                    el.classList.add('visible');
                } else {
                    io.observe(el);
                }
            });
        })();

        /* ══════════════════════════════════════════
           CONFETTI BURST — lightweight, 1.5s
        ══════════════════════════════════════════ */
        function launchConfetti() {
            const colors = ['#5ba4f5', '#b8d8fa', '#ffffff', '#2b6cb8', '#a0c8f0', '#7ec3f8'];
            const count = 42; // subtle, not overwhelming

            for (let i = 0; i < count; i++) {
                const el = document.createElement('div');
                el.className = 'confetti-piece';
                const size = 5 + Math.random() * 5;
                const delay = Math.random() * 0.6;
                const dur = 1.1 + Math.random() * 0.7;
                const dx = (Math.random() - 0.5) * 180;
                el.style.left = `${10 + Math.random() * 80}%`;
                el.style.width = `${size}px`;
                el.style.height = `${size * 1.4}px`;
                el.style.background = colors[Math.floor(Math.random() * colors.length)];
                el.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
                el.style.setProperty('--cf-dur', `${dur}s`);
                el.style.setProperty('--cf-del', `${delay}s`);
                el.style.setProperty('--cf-dx', `${dx}px`);
                document.body.appendChild(el);
                // Remove from DOM after animation completes
                setTimeout(() => el.remove(), (delay + dur + 0.2) * 1000);
            }
        }

        /* ══════════════════════════════════════════
           ENDING SCENE — PARTICLES + RINGS + REVEAL
        ══════════════════════════════════════════ */
        (function endingScene() {
            const endSection = $('scene-end');
            let built = false;

            onVisible([endSection], (t, io) => {
                if (built) return; built = true;
                io.unobserve(t); // Clean up observer after it triggers once

                // Stage 1: reveal quote + birthday line
                setTimeout(() => $('end-quote').classList.add('vis'), 200);
                setTimeout(() => $('end-sub').classList.add('vis'), 600);
                setTimeout(() => $('end-line').classList.add('vis'), 900);
                // Stage 2: after 3 seconds — "thank you" + "more loved" lines
                setTimeout(() => $('end-thank').classList.add('vis'), 3200);
                setTimeout(() => $('end-loved').classList.add('vis'), 4600);

                // Confetti burst at 1.2s — lightweight, 1.5s total
                setTimeout(() => launchConfetti(), 1200);

                // Rings
                [0, 1.8, 3.5].forEach(del => {
                    const r = document.createElement('div');
                    r.className = 'end-ring';
                    const sz = 280 + del * 40;
                    Object.assign(r.style, {
                        width: `${sz}px`, height: `${sz}px`,
                        '--del': `${del}s`,
                    });
                    endSection.appendChild(r);
                });

                // Lightweight particles — 28 max for mobile performance
                for (let i = 0; i < 28; i++) {
                    const p = document.createElement('div');
                    p.className = 'particle';
                    const size = 1.5 + Math.random() * 2.5;
                    const opacity = 0.15 + Math.random() * 0.28;
                    p.style.width = `${size}px`;
                    p.style.height = `${size}px`;
                    p.style.left = `${5 + Math.random() * 90}%`;
                    p.style.top = `${20 + Math.random() * 70}%`;
                    p.style.background = `rgba(91, 164, 245, ${opacity})`;
                    p.style.setProperty('--dur', `${7 + Math.random() * 9}s`);
                    p.style.setProperty('--del', `-${Math.random() * 9}s`);
                    p.style.setProperty('--hi', opacity);
                    p.style.setProperty('--dx', `${(Math.random() - 0.5) * 50}px`);
                    p.style.setProperty('--dy', `-${80 + Math.random() * 120}px`);
                    endSection.appendChild(p);
                }
            }, { threshold: 0.25 });
        })();
    </script>
</body>

